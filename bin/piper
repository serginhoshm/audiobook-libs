#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
VENV_PIPER="$ROOT_DIR/.venv/bin/piper"

if [ ! -x "$VENV_PIPER" ]; then
  echo "ERROR: Piper not found at $VENV_PIPER" >&2
  echo "Run ./setup/install_all.sh to install dependencies." >&2
  exit 1
fi

exec "$VENV_PIPER" "$@"
